{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-effects",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "dialog:default",
    "os:allow-platform",
    "os:allow-version",
    "os:allow-os-type",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "powershell",
          "cmd": "powershell.exe",
          "args": [
            "-NoProfile",
            "-NonInteractive",
            "-ExecutionPolicy",
            "Bypass",
            "-Command",
            { "validator": "[\\s\\S]+" }
          ],
          "sidecar": false
        },
        {
          "name": "winget",
          "cmd": "winget.exe",
          "args": true,
          "sidecar": false
        },
        {
          "name": "sc",
          "cmd": "sc.exe",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}
