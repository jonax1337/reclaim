{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reclaim",
  "version": "0.1.0-beta",
  "identifier": "dev.jonas.reclaim",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Reclaim",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": [
            "mica"
          ],
          "state": "active"
        },
        "backgroundColor": "#00000000",
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "shadow": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": [
          "en-US",
          "de-DE"
        ]
      }
    }
  }
}
